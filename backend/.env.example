# Backend environment variables
# Nusxa oling: copy .env.example .env  (Windows)  yoki  cp .env.example .env  (Linux/Mac)

# === Database ===
DATABASE_URL=sqlite:///./uzum.db
# PostgreSQL uchun:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# === Redis (Celery broker) ===
REDIS_URL=redis://localhost:6379/0

# === Security — productionda MAJBURIY ===
# Generatsiya:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change_me_to_a_long_random_string_at_least_64_chars

# Token shifrlash kaliti (Uzum API tokenlari DB'da Fernet bilan shifrlanadi).
# Bo'sh qoldirilsa SECRET_KEY'dan derive qilinadi (sodda variant).
# Aniq belgilash uchun:
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# Muhit — production / development
ENV=development

# === Birinchi admin (faqat baza bo'sh bo'lganda yaratiladi) ===
INITIAL_ADMIN_EMAIL=admin@local
INITIAL_ADMIN_PASSWORD=changeme_strong_password_min_8_chars

# === CORS ruxsat etilgan domenlar (vergul bilan) ===
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# === JWT ===
ACCESS_TOKEN_EXPIRE_MINUTES=1440
