# Backend environment variables
# Nusxa oling: cp .env.example .env

# Database
DATABASE_URL=sqlite:///./uzum.db
# PostgreSQL uchun: postgresql+psycopg2://user:pass@host:5432/dbname

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# Uzum API (https://api-seller.uzum.uz)
UZUM_API_TOKEN=your_uzum_api_token_here

# Security — production uchun MAJBURIY o'zgartiring
SECRET_KEY=change_me_to_a_long_random_string

# CORS allowed origins (vergul bilan ajratilgan)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
